.DS_Store

# Logs
logs
*.log
npm-debug.log*

# Runtime data
pids
*.pid
*.seed

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# temp build file
build/aiChatEntry.ts

# Dependency directories
node_modules
jspm_packages

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# IntelliJ/WebStorm Files
.idea
*.iml

dist
es
es-custom
lib
storybook-static
storybook-react-static

custom-elements.json

# env file
.env
env.cjs

stats.json
stats
stats.html
stats-docs.html
generated_docs

.cache-loader
.rollup.cache
tsconfig.tsbuildinfo

# VSCode files
.vscode

# Cypress test output files
test/cypress/screenshots
test/cypress/videos

.parcel-cache
parcel-bundle-reports

test-results

# NextJS cache filees
.next
next-env.d.ts

packages/ai-chat-components/scss
# Skill trees stay tracked: .bob/skills/ is canonical and .claude/skills/ is a
# generated mirror (npm run sync:skills), but both must be committed because
# each assistant only reads its own directory.
.bob/*
!.bob/skills/
.claude/*
!.claude/skills/

.playwright-mcp

# Agent working drafts (per-task throwaway, never committed).
# Issue bodies mirror live GitHub issues; PR drafts feed `gh pr create --body-file`;
# plan files are consumed by the epic or the merged PRs. See .bob/skills/README.md.
.github/issue-drafts/
.github/pr-drafts/
.github/plan-drafts/

# Legacy repo-root draft locations, superseded by .github/*-drafts/ above.
/PR.md
/PLAN*.md
